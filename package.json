{
  "name": "handless-app",
  "private": true,
  "version": "0.2.10",
  "type": "module",
  "description": "macOS desktop speech-to-text. Private, offline, open-source.",
  "keywords": [
    "speech-to-text",
    "voice-recognition",
    "tauri",
    "whisper",
    "desktop",
    "offline",
    "accessibility",
    "transcription"
  ],
  "homepage": "https://github.com/ElwinLiu/handless",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElwinLiu/handless.git"
  },
  "bugs": {
    "url": "https://github.com/ElwinLiu/handless/issues"
  },
  "author": "Elwin Liu",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write . && cd src-tauri && cargo fmt",
    "format:check": "prettier --check . && cd src-tauri && cargo fmt -- --check",
    "format:frontend": "prettier --write .",
    "format:backend": "cd src-tauri && cargo fmt",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "check:translations": "bun scripts/check-translations.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.16",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-sql": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.2",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "i18next": "^25.7.2",
    "immer": "^11.1.3",
    "motion": "^12.35.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.4.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.16",
    "tailwindcss-animate": "^1.0.7",
    "tauri-plugin-macos-permissions-api": "2.3.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tauri-apps/cli": "^2.9.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-i18next": "^6.1.3",
    "prettier": "^3.6.2",
    "typescript": "~5.9.0",
    "vite": "^7.0.0"
  }
}
